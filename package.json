{
  "name": "auth-app",
  "version": "1.0.0",
  "description": "Node.js Authentication App with Mocha/Chai tests and Jenkins CI",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "mocha --recursive tests --timeout 10000",
    "test:unit": "mocha tests/unit --timeout 5000",
    "test:integration": "mocha tests/integration --timeout 10000",
    "test:report": "mocha --recursive tests --reporter mochawesome --reporter-options reportDir=reports,reportFilename=test-report,quiet=true --timeout 10000"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.17.3"
  },
  "devDependencies": {
    "chai": "^4.3.10",
    "cheerio": "^1.0.0-rc.12",
    "mocha": "^10.2.0",
    "mochawesome": "^7.1.3",
    "supertest": "^6.3.3"
  }
}
